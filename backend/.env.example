# ─────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─────────────────────────────────────────────
# OTP
# ─────────────────────────────────────────────
# Long random string — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
OTP_HMAC_SECRET=replace-with-a-very-long-random-secret

# ─────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────
# Long random string — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-another-long-random-secret

# ─────────────────────────────────────────────
# SMS Gateway (sms-gate.app Android app)
# Install the app on your phone, note the IP shown
# ─────────────────────────────────────────────
SMS_GATEWAY_URL=http://192.168.1.x:8080
SMS_GATEWAY_LOGIN=your-app-login
SMS_GATEWAY_PASSWORD=your-app-password

# ─────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─────────────────────────────────────────────
# OPD / Appointment proxy (optional)
# ─────────────────────────────────────────────
# If set, backend will proxy OPD booking + uploads to this service
OPD_BASE_URL=https://appointment-management-system-pink.vercel.app
OPD_API_KEY=pgf-opd-key-2026
